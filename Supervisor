<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>لوحة المشرف — نظم وحلول</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{
  --bg:#0b0d14;--bg2:#10121a;--bg3:#161824;--bg4:#1d1f2e;--bg5:#23263a;
  --border:#262840;--border2:#32364e;
  --accent:#4f6ef7;--accent-l:#6c8fff;--accent-s:rgba(79,110,247,0.10);--accent-s2:rgba(79,110,247,0.18);
  --text:#e4e6f2;--text2:#8b92b8;--text3:#4e5370;
  --success:#34d399;--success-s:rgba(52,211,153,0.10);
  --danger:#f87171;--danger-s:rgba(248,113,113,0.10);
  --warning:#fbbf24;--warning-s:rgba(251,191,36,0.10);
  --purple:#a78bfa;--purple-s:rgba(167,139,250,0.10);
  --radius:12px;--radius-s:8px;--shadow:0 8px 32px rgba(0,0,0,0.5);
  --nav-w:220px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'IBM Plex Sans Arabic',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;}

/* LOGIN */
.login-wrap{position:fixed;inset:0;background:var(--bg);z-index:999;display:flex;align-items:center;justify-content:center;}
.login-card{background:var(--bg3);border:1px solid var(--border2);border-radius:16px;padding:2.5rem;width:380px;text-align:center;box-shadow:var(--shadow);}
.login-icon{width:60px;height:60px;background:var(--warning-s);border:1px solid rgba(251,191,36,0.3);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:26px;}
.login-title{font-family:'Tajawal',sans-serif;font-size:22px;font-weight:800;margin-bottom:6px;}
.login-sub{font-size:13px;color:var(--text3);margin-bottom:1.75rem;}
.login-field{margin-bottom:12px;text-align:right;}
.login-field label{font-size:12px;color:var(--text3);display:block;margin-bottom:6px;font-weight:500;}
.login-field select,.login-field input{width:100%;background:var(--bg4);border:1px solid var(--border);border-radius:var(--radius-s);color:var(--text);font-family:'IBM Plex Sans Arabic',sans-serif;font-size:14px;padding:11px 14px;outline:none;transition:border-color .2s;appearance:none;-webkit-appearance:none;}
.login-field input:focus,.login-field select:focus{border-color:var(--accent);}
.login-btn{width:100%;padding:12px;background:var(--warning);color:#000;border:none;border-radius:var(--radius-s);font-family:'IBM Plex Sans Arabic',sans-serif;font-size:14px;font-weight:700;cursor:pointer;margin-top:4px;transition:all .2s;}
.login-btn:hover{opacity:0.9;}
.login-err{color:var(--danger);font-size:13px;margin-top:10px;min-height:20px;}

/* SIDEBAR */
.sidebar{width:var(--nav-w);background:var(--bg2);border-left:1px solid var(--border);min-height:100vh;display:flex;flex-direction:column;position:fixed;right:0;top:0;bottom:0;z-index:50;}
.sidebar-brand{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);}
.brand-dot{width:7px;height:7px;background:var(--warning);border-radius:50%;box-shadow:0 0 8px var(--warning);display:inline-block;margin-left:8px;}
.brand-name{font-size:13px;font-weight:600;line-height:1.3;}
.brand-sub{font-size:11px;color:var(--text3);margin-top:2px;}
.sidebar-role{margin:1rem 1rem 0;background:var(--warning-s);border:1px solid rgba(251,191,36,0.25);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:600;color:var(--warning);text-align:center;}
.sidebar-team{margin:.5rem 1rem 0;background:var(--accent-s);border:1px solid rgba(79,110,247,0.2);border-radius:20px;padding:4px 12px;font-size:11px;color:var(--accent-l);text-align:center;}
.sidebar-nav{flex:1;padding:1rem 0.75rem;display:flex;flex-direction:column;gap:3px;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius-s);font-size:13px;font-weight:500;color:var(--text2);cursor:pointer;transition:all .15s;border:none;background:none;width:100%;text-align:right;}
.nav-item:hover{background:var(--bg4);color:var(--text);}
.nav-item.active{background:var(--accent-s2);color:var(--accent-l);}
.nav-item .ni{font-size:16px;min-width:20px;}
.nav-sep{height:1px;background:var(--border);margin:8px 0;}
.sidebar-footer{padding:1rem;border-top:1px solid var(--border);}
.logout-btn{width:100%;padding:9px;background:var(--danger-s);border:1px solid rgba(248,113,113,0.2);border-radius:var(--radius-s);color:var(--danger);font-family:'IBM Plex Sans Arabic',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;}
.logout-btn:hover{background:rgba(248,113,113,0.2);}

/* MAIN */
.main-wrap{margin-right:var(--nav-w);flex:1;min-height:100vh;display:flex;flex-direction:column;}
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 2rem;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40;}
.topbar-title{font-family:'Tajawal',sans-serif;font-size:18px;font-weight:700;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.topbar-date{font-size:12px;color:var(--text3);}
.content{flex:1;padding:2rem;max-width:1100px;width:100%;}

/* PANELS */
.panel{display:none;}
.panel.active{display:block;}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.75rem;}
.kpi-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.25rem;position:relative;overflow:hidden;}
.kpi-card::before{content:'';position:absolute;top:0;right:0;width:3px;height:100%;}
.kpi-card.c-blue::before{background:var(--accent);}
.kpi-card.c-green::before{background:var(--success);}
.kpi-card.c-yellow::before{background:var(--warning);}
.kpi-card.c-purple::before{background:var(--purple);}
.kpi-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;}
.kpi-value{font-family:'Tajawal',sans-serif;font-size:26px;font-weight:800;line-height:1;}
.kpi-value.c-blue{color:var(--accent-l);}
.kpi-value.c-green{color:var(--success);}
.kpi-value.c-yellow{color:var(--warning);}
.kpi-value.c-purple{color:var(--purple);}
.kpi-sub{font-size:11px;color:var(--text3);margin-top:4px;}

/* CHARTS */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:1.75rem;}
.chart-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;}
.chart-card.wide{grid-column:1/-1;}
.chart-title{font-size:13px;font-weight:600;color:var(--text2);margin-bottom:1rem;}
.chart-wrap{position:relative;height:200px;}

/* FILTERS */
.filter-bar{display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;margin-bottom:1.5rem;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:1rem 1.25rem;}
.filter-group{display:flex;flex-direction:column;gap:6px;min-width:150px;}
.filter-group label{font-size:11px;color:var(--text3);font-weight:500;text-transform:uppercase;letter-spacing:0.4px;}
select,input[type=text],input[type=date]{background:var(--bg4);border:1px solid var(--border);border-radius:var(--radius-s);color:var(--text);font-family:'IBM Plex Sans Arabic',sans-serif;font-size:13px;padding:8px 12px;outline:none;appearance:none;-webkit-appearance:none;transition:border-color .2s;}
select:focus,input:focus{border-color:var(--accent);}
select option{background:var(--bg3);}

/* CARD / TABLE */
.card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:1.25rem;}
.card-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:13px;font-weight:600;color:var(--text2);}
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead tr{background:var(--bg4);}
th{padding:10px 14px;font-weight:600;color:var(--text2);text-align:right;white-space:nowrap;border-bottom:1px solid var(--border2);}
td{padding:10px 14px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tbody tr:hover{background:var(--bg4);}
.td-trunc{max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* BADGES */
.badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;}
.badge-present{background:var(--success-s);color:var(--success);border:1px solid rgba(52,211,153,0.2);}
.badge-absent{background:var(--danger-s);color:var(--danger);border:1px solid rgba(248,113,113,0.2);}
.badge-holiday{background:var(--accent-s);color:var(--accent-l);border:1px solid rgba(79,110,247,0.2);}
.badge-leave{background:var(--warning-s);color:var(--warning);border:1px solid rgba(251,191,36,0.2);}

/* BUTTONS */
.btn{padding:8px 16px;border-radius:var(--radius-s);font-family:'IBM Plex Sans Arabic',sans-serif;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .2s;display:inline-flex;align-items:center;gap:6px;}
.btn:disabled{opacity:0.45;cursor:not-allowed;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover:not(:disabled){background:var(--accent-l);}
.btn-secondary{background:var(--bg4);border:1px solid var(--border2);color:var(--text);}
.btn-secondary:hover:not(:disabled){background:var(--bg5);}
.btn-danger{background:var(--danger-s);border:1px solid rgba(248,113,113,0.2);color:var(--danger);}
.btn-danger:hover:not(:disabled){background:rgba(248,113,113,0.2);}
.btn-sm{padding:5px 10px;font-size:12px;}

/* MGMT */
.mgmt-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:1.25rem;}
.mgmt-card-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.mgmt-card-title{font-size:13px;font-weight:600;color:var(--text2);}
.mgmt-card-body{padding:1rem 1.25rem;max-height:400px;overflow-y:auto;}
.mgmt-item{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
.mgmt-item:last-child{border-bottom:none;}
.item-name{font-size:14px;font-weight:500;}
.item-meta{font-size:11px;color:var(--text3);margin-top:2px;}
.add-row{display:flex;gap:8px;padding:1rem 1.25rem;border-top:1px solid var(--border);}
.add-row input,.add-row select{flex:1;padding:9px 12px;}

/* LINKS */
.links-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;}
.link-card{background:var(--bg4);border:1px solid var(--border);border-radius:var(--radius-s);padding:1rem 1.25rem;}
.link-emp{font-size:14px;font-weight:600;}
.link-role{font-size:11px;margin-top:2px;}
.link-url{font-size:11px;color:var(--text3);margin:8px 0;word-break:break-all;line-height:1.5;}
.btn-copy{background:none;border:1px solid var(--border);border-radius:6px;padding:5px 10px;color:var(--text2);cursor:pointer;font-size:12px;font-family:'IBM Plex Sans Arabic',sans-serif;transition:all .2s;}
.btn-copy:hover{border-color:var(--accent);color:var(--accent-l);}

/* ATT STATS */
.att-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:1.25rem;}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);z-index:200;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius);padding:1.75rem;width:420px;box-shadow:var(--shadow);}
.modal-title{font-size:16px;font-weight:700;margin-bottom:1.25rem;}
.modal-field{margin-bottom:12px;}
.modal-field label{font-size:12px;color:var(--text3);display:block;margin-bottom:6px;font-weight:500;}
.modal-field input,.modal-field select{width:100%;padding:10px 12px;}
.modal-actions{display:flex;gap:8px;margin-top:1.25rem;justify-content:flex-end;}
.btn-sm-cancel{background:var(--bg4);border:1px solid var(--border2);color:var(--text2);padding:8px 16px;border-radius:var(--radius-s);font-family:'IBM Plex Sans Arabic',sans-serif;font-size:13px;cursor:pointer;}
.btn-sm-confirm{background:var(--accent);color:#fff;padding:8px 16px;border-radius:var(--radius-s);font-family:'IBM Plex Sans Arabic',sans-serif;font-size:13px;font-weight:600;cursor:pointer;border:none;}

/* LOADING */
.loading-overlay{position:fixed;inset:0;background:var(--bg);z-index:900;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;}
.spin{width:38px;height:38px;border:3px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

/* TOAST */
.toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius);padding:11px 20px;font-size:13px;color:var(--text);opacity:0;transition:all .3s;z-index:999;white-space:nowrap;box-shadow:var(--shadow);display:flex;align-items:center;gap:10px;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast.success .t-icon{color:var(--success);}
.toast.error .t-icon{color:var(--danger);}

/* EMPTY */
.empty{text-align:center;padding:2.5rem;color:var(--text3);}
.empty-icon{font-size:32px;margin-bottom:8px;}
.empty-text{font-size:13px;}

::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}

@media(max-width:900px){
  .sidebar{display:none;}
  .main-wrap{margin-right:0;}
  .kpi-grid{grid-template-columns:repeat(2,1fr);}
  .charts-grid{grid-template-columns:1fr;}
  .att-stats{grid-template-columns:repeat(2,1fr);}
}
</style>
</head>
<body>

<!-- Loading -->
<div class="loading-overlay" id="loading-overlay">
  <div class="spin"></div>
  <div style="font-size:13px;color:var(--text2)">جاري التحميل...</div>
</div>

<!-- LOGIN -->
<div class="login-wrap" id="login-wrap">
  <div class="login-card">
    <div class="login-icon">👔</div>
    <div class="login-title">لوحة المشرف</div>
    <div class="login-sub">نظم وحلول للتقنية المالية</div>
    <div class="login-field">
      <label>اختر تيمك</label>
      <select id="login-team"></select>
    </div>
    <div class="login-field">
      <label>كلمة المرور</label>
      <input type="password" id="login-pass" placeholder="••••••••">
    </div>
    <button class="login-btn" onclick="doLogin()">دخول</button>
    <div class="login-err" id="login-err"></div>
  </div>
</div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar" style="display:none">
  <div class="sidebar-brand">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
      <span class="brand-dot"></span>
      <span class="brand-name">نظم وحلول</span>
    </div>
    <div class="brand-sub">للتقنية المالية</div>
  </div>
  <div class="sidebar-role">مشرف تيم</div>
  <div class="sidebar-team" id="sidebar-team-name">—</div>
  <nav class="sidebar-nav">
    <button class="nav-item active" id="nav-dashboard" onclick="switchPanel('dashboard')"><span class="ni">📊</span> الداشبورد</button>
    <button class="nav-item" id="nav-reports"    onclick="switchPanel('reports')">   <span class="ni">📋</span> التقارير</button>
    <button class="nav-item" id="nav-attendance" onclick="switchPanel('attendance')"><span class="ni">📅</span> الحضور</button>
    <div class="nav-sep"></div>
    <button class="nav-item" id="nav-employees"  onclick="switchPanel('employees')"> <span class="ni">👥</span> الموظفين</button>
    <button class="nav-item" id="nav-links"      onclick="switchPanel('links')">     <span class="ni">🔗</span> الروابط</button>
  </nav>
  <div class="sidebar-footer">
    <button class="logout-btn" onclick="doLogout()">تسجيل الخروج</button>
  </div>
</aside>

<!-- MAIN -->
<div class="main-wrap" id="main-wrap" style="display:none">
  <header class="topbar">
    <div class="topbar-title" id="topbar-title">الداشبورد</div>
    <div class="topbar-right">
      <span class="topbar-date" id="topbar-date"></span>
      <button class="btn btn-secondary btn-sm" onclick="refreshAll()">🔄 تحديث</button>
    </div>
  </header>

  <div class="content">

    <!-- DASHBOARD -->
    <div class="panel active" id="panel-dashboard">
      <div class="filter-bar">
        <div class="filter-group"><label>من تاريخ</label><input type="date" id="db-from"></div>
        <div class="filter-group"><label>إلى تاريخ</label><input type="date" id="db-to"></div>
        <div class="filter-group" style="justify-content:flex-end"><button class="btn btn-primary" onclick="loadDashboard()">تطبيق</button></div>
      </div>
      <div class="kpi-grid">
        <div class="kpi-card c-blue"><div class="kpi-label">إجمالي الساعات</div><div class="kpi-value c-blue" id="kpi-hours">—</div><div class="kpi-sub">ساعة عمل</div></div>
        <div class="kpi-card c-green"><div class="kpi-label">معدل الحضور</div><div class="kpi-value c-green" id="kpi-att">—</div><div class="kpi-sub">%</div></div>
        <div class="kpi-card c-purple"><div class="kpi-label">التقارير</div><div class="kpi-value c-purple" id="kpi-rep">—</div><div class="kpi-sub">سجل مهام</div></div>
        <div class="kpi-card c-yellow"><div class="kpi-label">الموظفين</div><div class="kpi-value c-yellow" id="kpi-emp">—</div><div class="kpi-sub">موظف نشط</div></div>
      </div>
      <div class="charts-grid">
        <div class="chart-card"><div class="chart-title">📈 الساعات اليومية</div><div class="chart-wrap"><canvas id="chart-daily"></canvas></div></div>
        <div class="chart-card"><div class="chart-title">✅ حضور الموظفين</div><div class="chart-wrap"><canvas id="chart-att"></canvas></div></div>
        <div class="chart-card wide"><div class="chart-title">🏢 أكثر العملاء مهاماً</div><div class="chart-wrap" style="height:160px"><canvas id="chart-clients"></canvas></div></div>
      </div>
    </div>

    <!-- REPORTS -->
    <div class="panel" id="panel-reports">
      <div class="filter-bar">
        <div class="filter-group"><label>الموظف</label><select id="rep-emp"><option value="">الكل</option></select></div>
        <div class="filter-group"><label>من تاريخ</label><input type="date" id="rep-from"></div>
        <div class="filter-group"><label>إلى تاريخ</label><input type="date" id="rep-to"></div>
        <div class="filter-group" style="justify-content:flex-end">
          <button class="btn btn-primary" onclick="loadReports()">بحث</button>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="card-title" id="rep-count">التقارير</span>
          <button class="btn btn-secondary btn-sm" onclick="exportReports()">⬇️ Excel</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>الموظف</th><th>التاريخ</th><th>العميل</th><th>نوع المهمة</th><th>من</th><th>إلى</th><th>المدة</th><th>الوصف</th></tr></thead>
            <tbody id="rep-tbody"><tr><td colspan="8"><div class="empty"><div class="empty-text">اضغط بحث لعرض التقارير</div></div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ATTENDANCE -->
    <div class="panel" id="panel-attendance">
      <div class="filter-bar">
        <div class="filter-group"><label>الموظف</label><select id="att-emp"><option value="">الكل</option></select></div>
        <div class="filter-group"><label>الشهر</label><input type="month" id="att-month"></div>
        <div class="filter-group" style="justify-content:flex-end"><button class="btn btn-primary" onclick="loadAttendance()">عرض</button></div>
      </div>
      <div class="att-stats">
        <div class="kpi-card c-green"><div class="kpi-label">حاضر</div><div class="kpi-value c-green" id="att-present">0</div></div>
        <div class="kpi-card" style="--c:var(--danger)"><div class="kpi-label">غياب</div><div class="kpi-value" style="color:var(--danger)" id="att-absent">0</div></div>
        <div class="kpi-card c-blue"><div class="kpi-label">إجازة</div><div class="kpi-value c-blue" id="att-holiday">0</div></div>
        <div class="kpi-card c-yellow"><div class="kpi-label">إجمالي</div><div class="kpi-value c-yellow" id="att-total">0</div></div>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">سجل الحضور</span></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>الموظف</th><th>التاريخ</th><th>الحالة</th><th>ملاحظة</th><th></th></tr></thead>
            <tbody id="att-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- EMPLOYEES -->
    <div class="panel" id="panel-employees">
      <div class="mgmt-card">
        <div class="mgmt-card-header">
          <span class="mgmt-card-title">👥 موظفي التيم</span>
          <span id="emp-count" style="font-size:12px;color:var(--text3)"></span>
        </div>
        <div class="mgmt-card-body" id="employees-list"></div>
        <div class="add-row">
          <input type="text" id="new-emp-name" placeholder="اسم الموظف الجديد">
          <select id="new-emp-role">
            <option value="موظف">موظف</option>
            <option value="مشرف">مشرف</option>
          </select>
          <button class="btn btn-primary" onclick="addEmployee()">إضافة</button>
        </div>
      </div>
    </div>

    <!-- LINKS -->
    <div class="panel" id="panel-links">
      <div class="links-grid" id="links-grid"></div>
    </div>

  </div>
</div>

<!-- Modal: Edit Attendance -->
<div class="modal-overlay" id="modal-att">
  <div class="modal">
    <div class="modal-title">تعديل الحضور</div>
    <div style="font-size:13px;color:var(--text2);margin-bottom:1rem" id="att-modal-info"></div>
    <div class="modal-field">
      <label>الحالة</label>
      <select id="att-status-sel">
        <option value="حاضر">حاضر</option>
        <option value="غياب">غياب</option>
        <option value="إجازة رسمية">إجازة رسمية</option>
        <option value="إجازة">إجازة</option>
      </select>
    </div>
    <div class="modal-field"><label>ملاحظة</label><input type="text" id="att-note-input" placeholder="ملاحظة اختيارية"></div>
    <div class="modal-actions">
      <button class="btn-sm-cancel" onclick="closeModal('modal-att')">إلغاء</button>
      <button class="btn-sm-confirm" onclick="confirmAttEdit()">حفظ</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"><span class="t-icon" id="t-icon">✓</span><span id="t-msg"></span></div>

<script>
const API = 'https://script.google.com/macros/s/AKfycbzyabhlwXLF2LDGzoR9RdvDZy_fyAXfbQO_EpKhwNE7zclPE8I8YNujf9pgquY55pMbhQ/exec';

let STATE = { teamId: null, teamName: null, teams: [], employees: [], clients: [] };
let charts = {};
let editingAtt = null;

async function apiFetch(p){ const r=await fetch(API+'?'+new URLSearchParams(p)); return r.json(); }
async function apiPost(a,d){ const r=await fetch(API,{method:'POST',body:JSON.stringify({action:a,...d})}); return r.json(); }

// ── LOGIN ──
async function initLogin() {
  try {
    const r = await apiFetch({ action: 'getTeams' });
    if (r.ok) {
      STATE.teams = r.teams || [];
      const sel = document.getElementById('login-team');
      sel.innerHTML = '<option value="">اختر التيم</option>';
      STATE.teams.forEach(t => { sel.innerHTML += `<option value="${t.id}">${t['اسم التيم']}</option>`; });
    }
  } catch(e) {}
  document.getElementById('loading-overlay').style.display = 'none';
}

async function doLogin() {
  const teamId = document.getElementById('login-team').value;
  const pass   = document.getElementById('login-pass').value;
  const errEl  = document.getElementById('login-err');
  errEl.textContent = '';
  if (!teamId) { errEl.textContent = 'اختر التيم أولاً'; return; }
  if (!pass)   { errEl.textContent = 'أدخل كلمة المرور'; return; }

  const team = STATE.teams.find(t => t.id === teamId);
  if (!team) { errEl.textContent = 'التيم غير موجود'; return; }

  if (pass !== team['كلمة مرور المشرف']) {
    errEl.textContent = 'كلمة المرور غلط';
    return;
  }

  STATE.teamId   = teamId;
  STATE.teamName = team['اسم التيم'];
  enterDashboard();
}

function enterDashboard() {
  document.getElementById('login-wrap').style.display   = 'none';
  document.getElementById('sidebar').style.display      = 'flex';
  document.getElementById('main-wrap').style.display    = 'flex';
  document.getElementById('sidebar-team-name').textContent = STATE.teamName;
  document.getElementById('topbar-date').textContent = new Date().toLocaleDateString('en-GB',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

  // Default dates
  const now      = new Date();
  const firstDay = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().slice(0,10);
  const today    = now.toISOString().slice(0,10);
  document.getElementById('db-from').value    = firstDay;
  document.getElementById('db-to').value      = today;
  document.getElementById('att-month').value  = today.slice(0,7);

  initData();
}

function doLogout() { location.reload(); }

// ── INIT DATA ──
async function initData() {
  document.getElementById('loading-overlay').style.display = 'flex';
  try {
    const [empsR, clientsR] = await Promise.all([
      apiFetch({ action: 'getEmployees', teamId: STATE.teamId }),
      apiFetch({ action: 'getClients' }),
    ]);
    if (empsR.ok)    STATE.employees = (empsR.employees || []).filter(e => e['نشط'] === 'نعم');
    if (clientsR.ok) STATE.clients   = clientsR.clients || [];
    populateFilters();
    await loadDashboard();
    renderEmployeesList();
    renderLinks();
  } catch(e) { showToast('تعذر تحميل البيانات','error'); }
  document.getElementById('loading-overlay').style.display = 'none';
}

function populateFilters() {
  ['rep-emp','att-emp'].forEach(id => {
    const sel = document.getElementById(id);
    sel.innerHTML = '<option value="">الكل</option>';
    STATE.employees.forEach(e => { sel.innerHTML += `<option value="${e.id}">${e['الاسم']}</option>`; });
  });
}

// ── DASHBOARD ──
async function loadDashboard() {
  const params = { action:'getDashboard', teamId: STATE.teamId };
  const from = document.getElementById('db-from').value;
  const to   = document.getElementById('db-to').value;
  if (from) params.dateFrom = from;
  if (to)   params.dateTo   = to;
  try {
    const r = await apiFetch(params);
    if (!r.ok) return;
    document.getElementById('kpi-hours').textContent = r.kpis.totalHours;
    document.getElementById('kpi-att').textContent   = r.kpis.attendanceRate;
    document.getElementById('kpi-rep').textContent   = r.kpis.totalReports;
    document.getElementById('kpi-emp').textContent   = STATE.employees.length;
    renderDailyChart(r.dailyHours);
    renderAttChart(r.attByTeam);
    renderClientsChart(r.topClients);
  } catch(e) {}
}

const COLORS = ['#4f6ef7','#34d399','#f87171','#fbbf24','#a78bfa','#38bdf8','#fb923c'];

function destroyChart(id){ if(charts[id]){charts[id].destroy();delete charts[id];} }

function chartOpts(){
  return{
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false}},
    scales:{
      x:{ticks:{color:'#4e5370',font:{family:'IBM Plex Sans Arabic',size:11}},grid:{color:'#1d1f2e'}},
      y:{ticks:{color:'#4e5370',font:{family:'IBM Plex Sans Arabic',size:11}},grid:{color:'#1d1f2e'}}
    }
  };
}

function renderDailyChart(data){
  destroyChart('daily');
  const ctx = document.getElementById('chart-daily').getContext('2d');
  charts['daily'] = new Chart(ctx,{
    type:'line',
    data:{labels:data.map(d=>d.date),datasets:[{label:'الساعات',data:data.map(d=>d.hours),borderColor:'#4f6ef7',backgroundColor:'rgba(79,110,247,0.08)',tension:0.4,fill:true,pointRadius:3}]},
    options:chartOpts()
  });
}

function renderAttChart(data){
  destroyChart('att');
  // بيانات الموظفين من الـ attendance
  const empNames = STATE.employees.map(e => e['الاسم']);
  const present  = STATE.employees.map(() => 0);
  // نحسب من البيانات المجمعة
  const ctx = document.getElementById('chart-att').getContext('2d');
  charts['att'] = new Chart(ctx,{
    type:'bar',
    data:{
      labels: data.map(d=>d.teamName||''),
      datasets:[
        {label:'حاضر',data:data.map(d=>d.present),backgroundColor:'#34d399',borderRadius:4},
        {label:'غياب',data:data.map(d=>d.absent), backgroundColor:'#f87171',borderRadius:4},
      ]
    },
    options:{...chartOpts(),scales:{x:{...chartOpts().scales.x,stacked:true},y:{...chartOpts().scales.y,stacked:true}}}
  });
}

function renderClientsChart(data){
  destroyChart('clients');
  const ctx = document.getElementById('chart-clients').getContext('2d');
  charts['clients'] = new Chart(ctx,{
    type:'bar',
    data:{
      labels:data.slice(0,8).map(d=>d.name.length>18?d.name.slice(0,18)+'…':d.name),
      datasets:[{label:'المهام',data:data.slice(0,8).map(d=>d.count),backgroundColor:'#a78bfa',borderRadius:5}]
    },
    options:{...chartOpts(),indexAxis:'y'}
  });
}

// ── REPORTS ──
async function loadReports(){
  const params = { action:'getReports', teamId: STATE.teamId };
  const emp  = document.getElementById('rep-emp').value;
  const from = document.getElementById('rep-from').value;
  const to   = document.getElementById('rep-to').value;
  if(emp)  params.empId    = emp;
  if(from) params.dateFrom = from;
  if(to)   params.dateTo   = to;

  const tbody = document.getElementById('rep-tbody');
  tbody.innerHTML = `<tr><td colspan="8"><div class="empty"><div class="spin" style="margin:auto"></div></div></td></tr>`;

  try {
    const r = await apiFetch(params);
    if(!r.ok) return;
    const rows = r.rows || [];
    document.getElementById('rep-count').textContent = `التقارير (${rows.length})`;
    if(!rows.length){tbody.innerHTML=`<tr><td colspan="8"><div class="empty"><div class="empty-icon">📋</div><div class="empty-text">لا توجد تقارير</div></div></td></tr>`;return;}
    tbody.innerHTML = rows.map(r=>`
      <tr>
        <td><strong>${r['اسم الموظف']||''}</strong></td>
        <td>${r['التاريخ']||''}</td>
        <td>${r['العميل']||''}</td>
        <td>${r['نوع المهمة']||''}</td>
        <td>${r['من']||''}</td>
        <td>${r['إلى']||''}</td>
        <td><span style="color:var(--success);font-weight:600">${r['المدة']||''}</span></td>
        <td class="td-trunc" title="${(r['وصف المهمة']||'').replace(/"/g,'&quot;')}">${r['وصف المهمة']||''}</td>
      </tr>`).join('');
    window._reportData = rows;
  } catch(e) { tbody.innerHTML=`<tr><td colspan="8"><div class="empty"><div class="empty-text">تعذر الاتصال</div></div></td></tr>`; }
}

function exportReports(){
  const data = window._reportData;
  if(!data||!data.length){showToast('لا توجد بيانات للتصدير');return;}
  const headers=['اسم الموظف','التاريخ','العميل','نوع المهمة','من','إلى','المدة','وصف المهمة'];
  const wsData=[headers,...data.map(r=>[r['اسم الموظف'],r['التاريخ'],r['العميل'],r['نوع المهمة'],r['من'],r['إلى'],r['المدة'],r['وصف المهمة']])];
  const ws=XLSX.utils.aoa_to_sheet(wsData);
  ws['!cols']=headers.map(()=>({wch:20}));
  const wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,ws,'التقارير');
  XLSX.writeFile(wb,`تقارير_${STATE.teamName}_${new Date().toISOString().slice(0,10)}.xlsx`);
  showToast('تم التصدير','success');
}

// ── ATTENDANCE ──
async function loadAttendance(){
  const params={action:'getAttendance',teamId:STATE.teamId};
  const emp   = document.getElementById('att-emp').value;
  const month = document.getElementById('att-month').value;
  if(emp)   params.empId  = emp;
  if(month) params.month  = month;

  const tbody=document.getElementById('att-tbody');
  tbody.innerHTML=`<tr><td colspan="5"><div class="empty"><div class="spin" style="margin:auto"></div></div></td></tr>`;

  try{
    const r=await apiFetch(params);
    if(!r.ok)return;
    const rows=r.rows||[];
    let present=0,absent=0,holiday=0;
    rows.forEach(r=>{
      if(r['الحالة']==='حاضر') present++;
      else if(r['الحالة']==='غياب') absent++;
      else if(r['الحالة']?.includes('إجازة')) holiday++;
    });
    document.getElementById('att-present').textContent=present;
    document.getElementById('att-absent').textContent=absent;
    document.getElementById('att-holiday').textContent=holiday;
    document.getElementById('att-total').textContent=rows.length;

    if(!rows.length){tbody.innerHTML=`<tr><td colspan="5"><div class="empty"><div class="empty-icon">📅</div><div class="empty-text">لا توجد سجلات</div></div></td></tr>`;return;}

    tbody.innerHTML=rows.map(row=>{
      const bc=row['الحالة']==='حاضر'?'badge-present':row['الحالة']==='غياب'?'badge-absent':row['الحالة']?.includes('رسمية')?'badge-holiday':'badge-leave';
      return`<tr>
        <td><strong>${row['اسم الموظف']||''}</strong></td>
        <td>${row['التاريخ']||''}</td>
        <td><span class="badge ${bc}">${row['الحالة']||''}</span></td>
        <td style="color:var(--text3);font-size:12px">${row['ملاحظة']||''}</td>
        <td><button class="btn btn-secondary btn-sm" onclick="openAttEdit('${row.emp_id}','${row['اسم الموظف']}','${row['التاريخ']}','${row['الحالة']}','${row['ملاحظة']||''}')">تعديل</button></td>
      </tr>`;
    }).join('');
  }catch(e){tbody.innerHTML=`<tr><td colspan="5"><div class="empty"><div class="empty-text">تعذر الاتصال</div></div></td></tr>`;}
}

function openAttEdit(empId,empName,date,status,note){
  editingAtt={empId,empName,teamId:STATE.teamId,date};
  document.getElementById('att-modal-info').textContent=`${empName} — ${date}`;
  document.getElementById('att-status-sel').value=status;
  document.getElementById('att-note-input').value=note||'';
  openModal('modal-att');
}

async function confirmAttEdit(){
  if(!editingAtt)return;
  const status=document.getElementById('att-status-sel').value;
  const note=document.getElementById('att-note-input').value;
  try{
    const r=await apiPost('updateAttendance',{...editingAtt,status,note});
    if(r.ok)showToast('تم التحديث','success');
    else showToast('حدث خطأ','error');
  }catch(e){showToast('تعذر الاتصال','error');}
  closeModal('modal-att');
  await loadAttendance();
}

// ── EMPLOYEES ──
function renderEmployeesList(){
  const el=document.getElementById('employees-list');
  document.getElementById('emp-count').textContent=`${STATE.employees.length} موظف`;
  if(!STATE.employees.length){el.innerHTML=`<div class="empty"><div class="empty-text">لا يوجد موظفين في هذا التيم</div></div>`;return;}
  el.innerHTML=STATE.employees.map(e=>`
    <div class="mgmt-item">
      <div>
        <div class="item-name">${e['الاسم']}</div>
        <div class="item-meta">${e['الدور']||'موظف'}</div>
      </div>
      <button class="btn btn-danger btn-sm" onclick="removeEmployee('${e.id}','${e['الاسم']}')">حذف</button>
    </div>`).join('');
}

async function addEmployee(){
  const name=document.getElementById('new-emp-name').value.trim();
  const role=document.getElementById('new-emp-role').value;
  if(!name){showToast('أدخل اسم الموظف');return;}
  try{
    const r=await apiPost('addEmployee',{name,teamId:STATE.teamId,role});
    if(r.ok){
      showToast('تمت الإضافة','success');
      document.getElementById('new-emp-name').value='';
      await refreshData();
    }else showToast(r.error||'خطأ','error');
  }catch(e){showToast('تعذر الاتصال','error');}
}

async function removeEmployee(id,name){
  if(!confirm(`حذف "${name}"؟`))return;
  try{
    const r=await apiPost('removeEmployee',{id});
    if(r.ok){showToast('تم الحذف','success');await refreshData();}
    else showToast(r.error||'خطأ','error');
  }catch(e){showToast('تعذر الاتصال','error');}
}

// ── LINKS ──
function renderLinks(){
  const grid=document.getElementById('links-grid');
  if(!STATE.employees.length){grid.innerHTML=`<div class="empty"><div class="empty-text">أضف موظفين أولاً</div></div>`;return;}
  const base=window.location.origin+window.location.pathname.replace('supervisor.html','')+'employee.html';
  grid.innerHTML=STATE.employees.map(e=>{
    const url=`${base}?empId=${e.id}&name=${encodeURIComponent(e['الاسم'])}&teamId=${STATE.teamId}`;
    const rc=e['الدور']==='مشرف'?'var(--warning)':'var(--success)';
    return`<div class="link-card">
      <div class="link-emp">${e['الاسم']}</div>
      <div class="link-role" style="color:${rc}">${e['الدور']||'موظف'}</div>
      <div class="link-url">${url}</div>
      <div style="display:flex;gap:6px;margin-top:8px">
        <button class="btn-copy" onclick="copyLink('${url}')">📋 نسخ</button>
        <a href="${url}" target="_blank" style="text-decoration:none"><button class="btn-copy">🔗 فتح</button></a>
      </div>
    </div>`;
  }).join('');
}

function copyLink(url){ navigator.clipboard.writeText(url).then(()=>showToast('تم نسخ الرابط','success')); }

// ── REFRESH ──
async function refreshData(){
  const r=await apiFetch({action:'getEmployees',teamId:STATE.teamId});
  if(r.ok) STATE.employees=(r.employees||[]).filter(e=>e['نشط']==='نعم');
  populateFilters();
  renderEmployeesList();
  renderLinks();
}

async function refreshAll(){
  document.getElementById('loading-overlay').style.display='flex';
  await refreshData();
  await loadDashboard();
  document.getElementById('loading-overlay').style.display='none';
  showToast('تم التحديث','success');
}

// ── UTILS ──
const PANELS=['dashboard','reports','attendance','employees','links'];
const TITLES={dashboard:'الداشبورد',reports:'التقارير',attendance:'الحضور',employees:'الموظفين',links:'روابط الموظفين'};
function switchPanel(name){
  PANELS.forEach(p=>{
    document.getElementById(`panel-${p}`)?.classList.toggle('active',p===name);
    document.getElementById(`nav-${p}`)?.classList.toggle('active',p===name);
  });
  document.getElementById('topbar-title').textContent=TITLES[name]||'';
}

function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
function showToast(msg,type='info'){
  const t=document.getElementById('toast');
  document.getElementById('t-msg').textContent=msg;
  document.getElementById('t-icon').textContent=type==='success'?'✓':'!';
  t.className=`toast ${type} show`;
  setTimeout(()=>t.classList.remove('show'),3500);
}

document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('login-pass').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin();});
  document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.modal-overlay.open').forEach(m=>m.classList.remove('open'));});
  document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
  initLogin();
});
</script>
</body>
</html>
